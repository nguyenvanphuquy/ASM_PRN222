@page
@model PresentationLayer.Pages.AllowedEmails.IndexModel
@{
    ViewData["Title"] = "Whitelist Email";
}

<div class="page-header">
    <h1>📧 Whitelist Email đăng ký</h1>
    <p>Quản lý danh sách email được phép tự đăng ký tài khoản Student</p>
</div>

<!-- Whitelist Status Banner -->
@if (Model.IsWhitelistEnabled)
{
    <div class="alert alert-success" style="margin-bottom:24px">
        🔒 <strong>Chế độ Whitelist Đang Bật</strong>: Chỉ những email thuộc danh sách bên dưới mới có thể tự đăng ký tài khoản. Các email khác sẽ bị chặn.
    </div>
}
else
{
    <div class="alert alert-info" style="margin-bottom:24px;border-color:var(--accent-orange);color:var(--accent-orange)">
        🔓 <strong>Chế độ Tự Do Đang Bật (Whitelist trống)</strong>: Hệ thống hiện đang mở tự do cho mọi email đăng ký tài khoản Student. Thêm ít nhất một email để kích hoạt chế độ chặn whitelist.
    </div>
}

<div style="display:grid;grid-template-columns:300px 1fr;gap:20px;align-items:start">
    <!-- Left: Add Email -->
    <div class="card">
        <h3 style="margin-bottom:16px;font-size:1.1rem;display:flex;align-items:center;gap:6px">
            <span>➕</span> Thêm email mới
        </h3>
        <form method="post" asp-page-handler="Add">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label" for="w_email">Email đăng ký *</label>
                <input id="w_email" name="email" type="email" class="form-control" placeholder="VD: student@fpt.edu.vn" required />
            </div>
            <div class="form-group">
                <label class="form-label" for="w_note">Ghi chú (Tên/Lý do)</label>
                <input id="w_note" name="note" class="form-control" placeholder="VD: Sinh viên PRN222" />
            </div>
            <button type="submit" class="btn btn-primary w-100" style="margin-top:12px">💾 Thêm vào whitelist</button>
        </form>
    </div>

    <!-- Right: Allowed emails table -->
    <div class="card" style="padding:0">
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Email được phép</th>
                        <th>Ghi chú</th>
                        <th>Người thêm</th>
                        <th>Ngày thêm</th>
                        <th class="text-right" style="text-align:right">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.AllowedEmails.Count == 0)
                    {
                        <tr>
                            <td colspan="5" style="text-align:center;padding:32px;color:var(--text-secondary)">
                                <div style="font-size:2rem;margin-bottom:8px">📧</div>
                                <div>Chưa có email nào trong whitelist. Chế độ đăng ký tự do đang hoạt động.</div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var e in Model.AllowedEmails)
                        {
                            <tr>
                                <td style="font-weight:600;color:var(--text-primary)">@e.Email</td>
                                <td>@(string.IsNullOrEmpty(e.Note) ? "–" : e.Note)</td>
                                <td class="text-sm">@e.AddedBy</td>
                                <td class="text-sm text-muted">@e.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <div class="flex gap-2" style="justify-content:flex-end">
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@e.Id" onsubmit="return confirm('Xoá email @e.Email khỏi whitelist?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-danger btn-sm">🗑️ Gỡ bỏ</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
