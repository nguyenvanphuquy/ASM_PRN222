@page
@model PresentationLayer.Pages.Feedback.IndexModel
@{
    ViewData["Title"] = "Phản hồi";
    ViewData["TopbarTitle"] = "💡 Phản hồi";
}

<div class="page-header">
    <h1>💡 Phản hồi</h1>
    <p>Gửi đánh giá và xem phản hồi của người dùng</p>
</div>

<!-- New Feedback Form -->
<div class="card mb-6">
    <div class="card-header"><span class="card-title">✍️ Gửi phản hồi mới</span></div>
    <form method="post">
        @Html.AntiForgeryToken()
        <div class="form-group">
            <label class="form-label">Đánh giá</label>
            <div style="display:flex;gap:8px" id="starRating">
                @for (int i = 1; i <= 5; i++)
                {
                    <input type="radio" name="Rating" value="@i" id="star@i"
                           checked="@(i == 5)" style="display:none" />
                    <label for="star@i" style="font-size:1.8rem;cursor:pointer;transition:transform 0.1s"
                           onmouseover="highlightStars(@i)" onmouseout="resetStars()"
                           onclick="selectStar(@i)">⭐</label>
                }
            </div>
        </div>
        <div class="form-group">
            <label class="form-label" for="Comment">Nội dung</label>
            <textarea id="Comment" asp-for="Comment" class="form-control" rows="3"
                      placeholder="Nhận xét về hệ thống, tài liệu..."></textarea>
        </div>
        <button type="submit" class="btn btn-primary">📤 Gửi phản hồi</button>
    </form>
</div>

<!-- List -->
@if (Model.Items.Count == 0)
{
    <div class="card"><div class="empty-state">
        <div class="empty-state-icon">💡</div>
        <div class="empty-state-title">Chưa có phản hồi nào</div>
    </div></div>
}
else
{
    <div style="display:flex;flex-direction:column;gap:12px">
        @foreach (var fb in Model.Items.OrderByDescending(x => x.CreatedAt))
        {
            <div class="card">
                <div style="display:flex;justify-content:space-between;align-items:flex-start">
                    <div>
                        <div style="font-weight:600;margin-bottom:4px">@fb.UserName</div>
                        <div style="margin-bottom:8px">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span style="color:@(i <= fb.Rating ? "var(--accent-orange)" : "var(--text-muted)")">★</span>
                            }
                        </div>
                        <p class="text-sm">@fb.Content</p>
                    </div>
                    <div class="text-sm text-muted">@fb.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
<script>
let selectedStar = 5;
function highlightStars(n) {
    document.querySelectorAll('#starRating label').forEach((l, i) => {
        l.style.transform = i < n ? 'scale(1.2)' : 'scale(1)';
        l.style.opacity = i < n ? '1' : '0.4';
    });
}
function resetStars() {
    document.querySelectorAll('#starRating label').forEach((l, i) => {
        l.style.transform = 'scale(1)';
        l.style.opacity = i < selectedStar ? '1' : '0.4';
    });
}
function selectStar(n) {
    selectedStar = n;
    document.getElementById('star' + n).checked = true;
}
resetStars();
</script>
}
