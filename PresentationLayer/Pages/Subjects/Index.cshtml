@page
@model PresentationLayer.Pages.Subjects.IndexModel
@using ServiceLayer.DTOs
@{
    ViewData["Title"] = "Môn học";
}

<div class="page-header">
    <h1>📚 Môn học</h1>
    <p>Danh sách môn học trong hệ thống</p>
</div>

@if (Model.Subjects.Count == 0)
{
    <div class="card"><div class="empty-state">
        <div class="empty-state-icon">📚</div>
        <div class="empty-state-title">Chưa có môn học</div>
    </div></div>
}
else
{
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px">
        @foreach (var s in Model.Subjects)
        {
            <div class="card" style="cursor:pointer" onclick="location.href='/Documents?SubjectId=@s.Id'">
                <div style="font-size:2rem;margin-bottom:12px">📚</div>
                <h3 style="font-size:1rem;margin-bottom:6px">@s.Name</h3>
                <p class="text-sm text-muted">@s.Code</p>
                <div class="flex gap-2 mt-4">
                    <a href="/Documents?SubjectId=@s.Id" class="btn btn-secondary btn-sm" onclick="event.stopPropagation()">📄 Tài liệu</a>
                    <a href="/Subjects/Chapters/@s.Id" class="btn btn-secondary btn-sm" onclick="event.stopPropagation()">📖 Chương</a>
                    <a href="/Chat" class="btn btn-primary btn-sm" onclick="event.stopPropagation()">💬 Chat</a>
                </div>
            </div>
        }
    </div>
}

