@using System.Security.Claims
@{
    var user = User;
    var isAuth = user.Identity?.IsAuthenticated ?? false;
    var userName = user.FindFirst(ClaimTypes.Name)?.Value ?? user.Identity?.Name ?? "Guest";
    var fullName = user.FindFirst("FullName")?.Value ?? userName;
    var role = user.FindFirst(ClaimTypes.Role)?.Value ?? "";
    var avatarPath = user.FindFirst("AvatarPath")?.Value;
    var isCanUpload = role == "Admin" || role == "Lecturer" || user.HasClaim("CanUpload", "true");
    var initials = fullName.Length > 0 ? fullName[0].ToString().ToUpper() : "?";
    var pageTitle = (string?)ViewData["Title"] ?? "ChatBot PRN222";
    var topbarTitle = (string?)ViewData["TopbarTitle"] ?? pageTitle;

    // Active page detection
    var path = Context.Request.Path.Value?.ToLower() ?? "";
    bool IsActive(string segment) => path.StartsWith(segment);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="ChatBot PRN222 – Hệ thống hỗ trợ học tập AI" />
    <title>@pageTitle – ChatBot PRN222</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🤖</text></svg>" />
</head>
<body>
@if (!isAuth)
{
    <!-- Unauthenticated: just render page content without sidebar -->
    @RenderBody()
}
else
{
<div class="app-shell">
    <!-- ── Sidebar ── -->
    <aside class="sidebar" id="sidebar">
        <a class="sidebar-logo" href="/Dashboard">
            <div class="sidebar-logo-icon">🤖</div>
            <div class="sidebar-logo-text">
                ChatBot
                <span>PRN222 · Razor</span>
            </div>
        </a>

        <nav class="sidebar-nav">
            @if (role == "Lecturer")
            {
                <a class="nav-item @(IsActive("/dashboard") ? "active" : "")" href="/Dashboard">
                    <span class="nav-icon">🏠</span> Bảng điều khiển
                </a>
                <a class="nav-item @(path == "/documents" || path == "/documents/" ? "active" : "")" href="/Documents">
                    <span class="nav-icon">📂</span> Quản lý tài liệu
                </a>
                @* <a class="nav-item @(IsActive("/subjects") ? "active" : "")" href="/Subjects">
                    <span class="nav-icon">📖</span> Quản lý môn học
                </a> *@
                <a class="nav-item @(IsActive("/chat") ? "active" : "")" href="/Chat">
                    <span class="nav-icon">🤖</span> Kiểm thử Chatbot
                </a>
                <a class="nav-item @(IsActive("/settings") ? "active" : "")" href="/Settings">
                    <span class="nav-icon">⚙️</span> Cài đặt
                </a>
                <a class="nav-item @(IsActive("/feedback") ? "active" : "")" href="/Feedback">
                    <span class="nav-icon">💡</span> Gửi phản hồi
                </a>
                <a class="nav-item @(IsActive("/profile") ? "active" : "")" href="/Profile">
                    <span class="nav-icon">👤</span> Hồ sơ
                </a>
                <a class="nav-item nav-logout" href="/Auth/Logout">
                    <span class="nav-icon">🚪</span> Đăng xuất
                </a>
            }
            else if (role == "Admin")
            {
                <a class="nav-item @(IsActive("/dashboard") ? "active" : "")" href="/Dashboard">
                    <span class="nav-icon">🏠</span> Bảng điều khiển
                </a>
                <a class="nav-item @(IsActive("/users") ? "active" : "")" href="/Users">
                    <span class="nav-icon">👥</span> Quản lý người dùng
                </a>
                <a class="nav-item @(IsActive("/allowedemails") ? "active" : "")" href="/AllowedEmails">
                    <span class="nav-icon">📧</span> Whitelist Email
                </a>
                <a class="nav-item @(IsActive("/subjects") ? "active" : "")" href="/Subjects">
                    <span class="nav-icon">📖</span> Quản lý môn học
                </a>
                <a class="nav-item @(path == "/documents" || path == "/documents/" ? "active" : "")" href="/Documents">
                    <span class="nav-icon">📂</span> Giám sát tài liệu
                </a>
                <a class="nav-item @(IsActive("/settings") ? "active" : "")" href="/Settings">
                    <span class="nav-icon">⚙️</span> Giám sát hệ thống
                </a>
                <a class="nav-item @(IsActive("/auditlogs") ? "active" : "")" href="/AuditLogs">
                    <span class="nav-icon">📜</span> Nhật ký hệ thống
                </a>
                <a class="nav-item @(IsActive("/feedback") ? "active" : "")" href="/Feedback">
                    <span class="nav-icon">💡</span> Quản lý phản hồi
                </a>
                <a class="nav-item @(IsActive("/profile") ? "active" : "")" href="/Profile">
                    <span class="nav-icon">👤</span> Hồ sơ
                </a>
                <a class="nav-item nav-logout" href="/Auth/Logout">
                    <span class="nav-icon">🚪</span> Đăng xuất
                </a>
            }
            else
            {
                <a class="nav-item @(IsActive("/dashboard") ? "active" : "")" href="/Dashboard">
                    <span class="nav-icon">🏠</span> Bảng điều khiển
                </a>
                <a class="nav-item @(IsActive("/subjects") ? "active" : "")" href="/Subjects">
                    <span class="nav-icon">📚</span> Môn học
                </a>
                <a class="nav-item @(IsActive("/chat/session") ? "active" : "")" href="/Chat">
                    <span class="nav-icon">🤖</span> Trợ lý AI
                </a>
                <a class="nav-item @(path == "/chat" || path == "/chat/" ? "active" : "")" href="/Chat">
                    <span class="nav-icon">🕒</span> Lịch sử trò chuyện
                </a>
                <a class="nav-item @(IsActive("/feedback") ? "active" : "")" href="/Feedback">
                    <span class="nav-icon">💡</span> Gửi phản hồi
                </a>
                <a class="nav-item @(IsActive("/profile") ? "active" : "")" href="/Profile">
                    <span class="nav-icon">👤</span> Hồ sơ
                </a>
                <a class="nav-item nav-logout" href="/Auth/Logout">
                    <span class="nav-icon">🚪</span> Đăng xuất
                </a>
            }
        </nav>

        <div class="sidebar-footer">
            <div class="user-card">
                <div class="user-avatar">
                    @if (!string.IsNullOrEmpty(avatarPath))
                    {
                        <img src="@avatarPath" alt="Avatar" />
                    }
                    else
                    {
                        @initials
                    }
                </div>
                <div class="user-info">
                    <div class="user-name">@fullName</div>
                    <div class="user-role">@role</div>
                </div>
                <a href="/Auth/Logout" class="user-logout" title="Đăng xuất">🚪</a>
            </div>
        </div>
    </aside>

    <!-- ── Main Content ── -->
    <div class="main-content">
        <header class="topbar">
            <button class="btn btn-secondary btn-icon" id="sidebarToggle" style="display:none" title="Menu">☰</button>
            <h2 class="topbar-title" style="font-size:1rem;font-weight:600;">@topbarTitle</h2>
            <div class="topbar-actions">
                <!-- 🔔 Notification Bell + Dropdown -->
                <div style="position:relative;display:inline-flex;align-items:center" id="notifWrapper">
                    <button id="notifBell" title="Thông báo"
                            style="background:none;border:none;font-size:1.3rem;cursor:pointer;padding:4px 8px;position:relative;color:inherit"
                            onclick="toggleNotifPanel(event)">
                        🔔
                        <span id="notifBadge" style="display:none;position:absolute;top:0;right:0;
                              background:#ef4444;color:#fff;border-radius:50%;font-size:0.6rem;
                              width:16px;height:16px;line-height:16px;text-align:center;font-weight:700">0</span>
                    </button>

                    <!-- Dropdown panel -->
                    <div id="notifPanel" style="display:none;position:absolute;top:calc(100% + 8px);right:0;
                         width:320px;max-height:400px;overflow-y:auto;
                         background:var(--surface,#1e293b);border:1px solid var(--border-color,#334155);
                         border-radius:12px;box-shadow:0 12px 32px rgba(0,0,0,0.4);z-index:9998">
                        <div style="padding:12px 16px;border-bottom:1px solid var(--border-color,#334155);
                                    display:flex;justify-content:space-between;align-items:center">
                            <span style="font-weight:600;font-size:0.9rem">🔔 Thông báo</span>
                            <button onclick="clearNotifPanel()" style="background:none;border:none;
                                    font-size:0.75rem;color:var(--text-muted,#94a3b8);cursor:pointer">
                                Xóa tất cả
                            </button>
                        </div>
                        <div id="notifList">
                            <div id="notifEmpty" style="padding:24px;text-align:center;color:var(--text-muted,#94a3b8);font-size:0.85rem">
                                Chưa có thông báo nào
                            </div>
                        </div>
                    </div>
                </div>
                <a href="/Chat" class="btn btn-primary btn-sm">
                    💬 Chat mới
                </a>
            </div>
        </header>

        <!-- 🍞 Toast container -->
        <div id="toastContainer" style="position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:10px;max-width:360px"></div>

        <main class="page-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success animate-fade-in">✅ @TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger animate-fade-in">❌ @TempData["Error"]</div>
            }
            @if (TempData["Info"] != null)
            {
                <div class="alert alert-info animate-fade-in">ℹ️ @TempData["Info"]</div>
            }

            @RenderBody()
        </main>
    </div>
</div>

<script>
    // Mobile sidebar toggle
    const sidebar = document.getElementById('sidebar');
    const toggle = document.getElementById('sidebarToggle');
    if (toggle) {
        toggle.addEventListener('click', () => sidebar.classList.toggle('open'));
        if (window.innerWidth <= 768) toggle.style.display = 'flex';
    }
    window.addEventListener('resize', () => {
        if (window.innerWidth <= 768) toggle.style.display = 'flex';
        else { toggle.style.display = 'none'; sidebar.classList.remove('open'); }
    });
</script>

<!-- SignalR Notification -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"
        crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script>
(function() {
    const toastEl = document.getElementById('toastContainer');
    const badge   = document.getElementById('notifBadge');
    let unread = 0;

    const colors = {
        success: { bg: '#16a34a', icon: '✅' },
        error:   { bg: '#dc2626', icon: '❌' },
        warning: { bg: '#d97706', icon: '⚠️' },
        info:    { bg: '#2563eb', icon: 'ℹ️' },
    };

    // Keep track of notifications in a list
    const notifs = [];

    window.toggleNotifPanel = async function(e) {
        e.stopPropagation();
        const panel = document.getElementById('notifPanel');
        const isHidden = panel.style.display === 'none';
        panel.style.display = isHidden ? 'block' : 'none';
        if (isHidden) {
            unread = 0;
            badge.style.display = 'none';
            // Mark as read in DB
            try {
                await fetch('/api/notifications/read-all', { method: 'POST' });
            } catch(e) { console.error('Error marking notifications as read', e); }
        }
    };

    window.clearNotifPanel = function() {
        notifs.length = 0;
        renderNotifList();
    };

    document.addEventListener('click', e => {
        const panel = document.getElementById('notifPanel');
        const wrapper = document.getElementById('notifWrapper');
        if (panel && wrapper && panel.style.display === 'block' && !wrapper.contains(e.target)) {
            panel.style.display = 'none';
        }
    });

    function renderNotifList() {
        const listEl = document.getElementById('notifList');
        if (notifs.length === 0) {
            listEl.innerHTML = '<div id="notifEmpty" style="padding:24px;text-align:center;color:var(--text-muted,#94a3b8);font-size:0.85rem">Chưa có thông báo nào</div>';
            return;
        }

        listEl.innerHTML = '';
        notifs.forEach(n => {
            const c = colors[n.type] || colors.info;
            const item = document.createElement('div');
            item.style.cssText = 'padding:12px 16px;border-bottom:1px solid var(--border-color,#334155);display:flex;gap:12px;align-items:flex-start;';
            item.innerHTML = `
                <span style="font-size:1.2rem;flex-shrink:0">${c.icon}</span>
                <div style="flex:1;min-width:0">
                    <div style="font-weight:600;font-size:0.85rem;margin-bottom:2px ${!n.isRead ? ';color:var(--text-color)' : ';color:var(--text-muted)'}">${escHtml(n.title)}</div>
                    <div style="font-size:0.75rem;color:var(--text-muted,#94a3b8);line-height:1.4">${escHtml(n.message)}</div>
                    <div style="font-size:0.65rem;color:var(--text-muted,#94a3b8);margin-top:4px">${escHtml(n.time)}</div>
                </div>`;
            listEl.appendChild(item);
        });
    }

    // Load initial notifications
    async function loadNotifications() {
        try {
            const res = await fetch('/api/notifications');
            if (res.ok) {
                const data = await res.json();
                notifs.push(...data);
                unread = data.filter(x => !x.isRead).length;
                if (unread > 0) {
                    badge.textContent = unread > 9 ? '9+' : unread;
                    badge.style.display = '';
                }
                renderNotifList();
            }
        } catch(e) { console.error('Failed to load notifications', e); }
    }
    
    // Call load on startup
    loadNotifications();

    function showToast(data) {
        const time = data.time || new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
        const type = data.type;
        const title = data.title;
        const message = data.message;
        
        // Add to history list
        notifs.unshift({ id: data.id, type, title, message, time, isRead: false });
        if (notifs.length > 20) notifs.pop();
        renderNotifList();

        const c = colors[type] || colors.info;
        const toast = document.createElement('div');
        toast.innerHTML = `
            <div style="background:${c.bg};color:#fff;border-radius:12px;padding:14px 16px;
                        box-shadow:0 8px 24px rgba(0,0,0,0.3);display:flex;gap:12px;align-items:flex-start;
                        animation:slideInToast 0.35s ease; cursor:pointer"
                 onclick="this.remove()">
                <span style="font-size:1.3rem;flex-shrink:0">${c.icon}</span>
                <div style="flex:1;min-width:0">
                    <div style="font-weight:700;font-size:0.9rem;margin-bottom:2px">${escHtml(title)}</div>
                    <div style="font-size:0.82rem;opacity:0.92;line-height:1.4">${escHtml(message)}</div>
                </div>
                <button onclick="event.stopPropagation(); this.closest('div').parentElement.remove()"
                        style="background:none;border:none;color:#fff;opacity:0.7;cursor:pointer;font-size:1.1rem;padding:0;flex-shrink:0">×</button>
            </div>`;
        toastEl.appendChild(toast);
        setTimeout(() => toast.remove(), 7000);

        // Update badge only if panel is closed
        const panel = document.getElementById('notifPanel');
        if (!panel || panel.style.display === 'none') {
            unread++;
            badge.textContent = unread > 9 ? '9+' : unread;
            badge.style.display = '';
        }
    }

    function escHtml(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    // Add CSS animation
    const style = document.createElement('style');
    style.textContent = `@@keyframes slideInToast {
        from { transform: translateX(120%); opacity: 0; }
        to   { transform: translateX(0);    opacity: 1; }
    }`;
    document.head.appendChild(style);

    // Connect SignalR
    const conn = new signalR.HubConnectionBuilder()
        .withUrl('/hubs/notifications')
        .withAutomaticReconnect()
        .build();

    conn.on('ReceiveNotification', data => {
        showToast(data);
    });

    // Expose the live notification connection so individual pages (e.g. Documents)
    // can subscribe to extra realtime events like 'DocumentStatusChanged'
    // without opening a second connection.
    window.appNotifHub = conn;

    conn.start().catch(e => console.warn('Notification hub:', e));
})();
</script>
}

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
